#!/bin/bash

# RSecure Launcher Script
# Main executable for RSecure system

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Default configuration
CONFIG_FILE="$PROJECT_ROOT/rsecure_config.json"
VENV_DIR="$PROJECT_ROOT/rsecure_env"
LOG_FILE="$PROJECT_ROOT/logs/rsecure.log"

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_header() {
    echo -e "${BLUE}=== $1 ===${NC}"
}

# Function to check dependencies
check_dependencies() {
    print_header "Checking Dependencies"
    
    # Check Python
    if ! command -v python3 &> /dev/null; then
        print_error "Python 3 is not installed"
        exit 1
    fi
    
    # Check virtual environment
    if [ ! -d "$VENV_DIR" ]; then
        print_warning "Virtual environment not found, creating..."
        python3 -m venv "$VENV_DIR"
    fi
    
    # Check configuration file
    if [ ! -f "$CONFIG_FILE" ]; then
        print_warning "Configuration file not found, using defaults"
    fi
    
    # Create logs directory
    mkdir -p "$(dirname "$LOG_FILE")"
    
    print_status "Dependencies check completed"
}

# Function to activate virtual environment
activate_venv() {
    if [ -f "$VENV_DIR/bin/activate" ]; then
        source "$VENV_DIR/bin/activate"
        print_status "Virtual environment activated"
    else
        print_error "Virtual environment not found at $VENV_DIR"
        exit 1
    fi
}

# Function to run RSecure with different modes
run_rsecure() {
    local mode="$1"
    
    print_header "Starting RSecure - $mode Mode"
    
    case "$mode" in
        "dashboard")
            cd "$PROJECT_ROOT"
            python run_rsecure_with_dashboard.py
            ;;
        "minimal")
            cd "$PROJECT_ROOT"
            python simple_dashboard.py
            ;;
        "console")
            cd "$PROJECT_ROOT/rsecure"
            python rsecure_main.py
            ;;
        "ollama")
            cd "$PROJECT_ROOT"
            python ollama_rsecure.py
            ;;
        "enhanced")
            cd "$PROJECT_ROOT"
            python rsecure_enhanced.py
            ;;
        *)
            print_error "Unknown mode: $mode"
            show_help
            exit 1
            ;;
    esac
}

# Function to show help
show_help() {
    echo "RSecure Launcher Script"
    echo ""
    echo "Usage: $0 [MODE] [OPTIONS]"
    echo ""
    echo "Modes:"
    echo "  dashboard    Launch with web dashboard (default)"
    echo "  minimal      Launch minimal dashboard"
    echo "  console      Launch console mode only"
    echo "  ollama       Launch with Ollama integration"
    echo "  enhanced     Launch enhanced version"
    echo ""
    echo "Options:"
    echo "  --config FILE    Use specific configuration file"
    echo "  --debug          Enable debug logging"
    echo "  --check-deps     Check dependencies only"
    echo "  --help           Show this help message"
    echo ""
    echo "Examples:"
    echo "  $0                    # Launch with dashboard"
    echo "  $0 console            # Console mode"
    echo "  $0 --config custom.json  # Custom config"
    echo "  $0 --debug            # Debug mode"
}

# Function to parse arguments
parse_args() {
    MODE="dashboard"
    DEBUG_FLAG=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            --debug)
                DEBUG_FLAG="--debug"
                shift
                ;;
            --check-deps)
                check_dependencies
                exit 0
                ;;
            --help)
                show_help
                exit 0
                ;;
            dashboard|minimal|console|ollama|enhanced)
                MODE="$1"
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    export RSECURE_CONFIG="$CONFIG_FILE"
    if [ -n "$DEBUG_FLAG" ]; then
        export RSECURE_DEBUG=1
    fi
}

# Function to handle cleanup
cleanup() {
    print_status "Cleaning up..."
    # Add any cleanup tasks here
}

# Main execution
main() {
    # Set up error handling
    trap cleanup EXIT
    
    print_header "RSecure Launcher"
    
    # Parse command line arguments
    parse_args "$@"
    
    # Check dependencies
    check_dependencies
    
    # Activate virtual environment
    activate_venv
    
    # Run RSecure
    run_rsecure "$MODE"
}

# Run main function with all arguments
main "$@"
