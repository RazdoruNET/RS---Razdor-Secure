{
  "system_detection": {
    "enabled": true,
    "config_file": "./system_config.json"
  },
  "monitoring": {
    "enabled": true,
    "log_dir": "/var/log/rsecure",
    "log_interval": 1,
    "network_scan_interval": 30,
    "file_scan_interval": 60,
    "monitor_paths": [
      "/etc", "/bin", "/sbin", "/usr/bin", "/usr/sbin",
      "/System/Library", "/Library", "/Applications"
    ],
    "network_ports": [22, 80, 443, 3306, 5432, 6379, 27017],
    "alert_threshold": 0.8
  },
  "neural_core": {
    "enabled": true,
    "model_dir": "./models",
    "analysis_interval": 5,
    "threat_threshold": 0.7,
    "sequence_length": 50,
    "feature_dim": 64,
    "num_classes": 5,
    "learning_rate": 0.001,
    "batch_size": 32,
    "epochs": 100
  },
  "analytics": {
    "enabled": true,
    "db_path": "./rsecure_analytics.db",
    "analysis_interval": 60,
    "trend_window": 24,
    "alert_threshold": 0.7,
    "report_retention_days": 90,
    "auto_correlation": true,
    "ml_enabled": true
  },
  "system_control": {
    "enabled": true,
    "auto_kill_threshold": 0.9,
    "auto_block_threshold": 0.8,
    "quarantine_dir": "./quarantine",
    "max_kill_attempts": 3,
    "kill_timeout": 10,
    "network_block_duration": 3600,
    "require_confirmation": false,
    "log_all_actions": true
  },
  "cvu_intelligence": {
    "enabled": true,
    "save_dir": "./data",
    "interval_min": 7,
    "max_results": 100,
    "days_back": 7,
    "request_timeout": 20,
    "auto_classify": true,
    "enable_kev": true,
    "enable_nvd": true,
    "enable_ghsa": true
  },
  "reinforcement_learning": {
    "enabled": true,
    "state_dim": 128,
    "action_dim": 20,
    "memory_size": 10000,
    "epsilon_start": 1.0,
    "epsilon_decay": 0.995,
    "epsilon_min": 0.01,
    "gamma": 0.95,
    "learning_rate": 0.001,
    "batch_size": 32,
    "target_update_freq": 100,
    "training_interval": 10,
    "save_interval": 100,
    "model_path": "./rl_models",
    "min_experiences": 1000
  },
  "network_defense": {
    "enabled": true,
    "monitored_ports": [22, 80, 443, 3389, 1433, 3306, 5432, 6379, 27017],
    "auto_block_threshold": 10,
    "block_duration": 3600,
    "max_block_duration": 86400,
    "packet_capture_size": 65535,
    "analysis_interval": 5,
    "enable_honeypot": true,
    "honeypot_ports": [8080, 8888, 9999],
    "enable_rate_limiting": true,
    "rate_limit_threshold": 100,
    "enable_port_scanning_detection": true,
    "enable_ddos_detection": true,
    "enable_brute_force_detection": true,
    "enable_anomaly_detection": true
  },
  "integration": {
    "enable_ml_decisions": true,
    "enable_auto_response": true,
    "enable_correlation": true,
    "decision_threshold": 0.8
  }
}
